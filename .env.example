# ── Supabase (free tier at supabase.com) ──────────────────
# Get these from: Supabase Dashboard > Settings > API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── CallMeBot WhatsApp (100% free, no credit card) ────────
# Setup guide in README — takes 2 minutes
# Doctor's WhatsApp number with country code (no spaces)
DOCTOR_PHONE=+919876543210
CALLMEBOT_API_KEY=123456

# ── Admin dashboard protection ────────────────────────────
# Choose any secret key — used to view all appointments
ADMIN_KEY=your-secret-admin-key-here

# ── CORS — set to your frontend URL after deploying ───────
FRONTEND_URL=https://your-clinic-site.netlify.app

# ── Server port (Render sets this automatically) ──────────
PORT=3000
